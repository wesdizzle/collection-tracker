{
  "$schema": "../node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.svg",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|apple-touch-icon|png|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-freshness",
      "urls": [
        "**/api/**"
      ],
      "cacheConfig": {
        "maxSize": 100,
        "maxAge": "30d",
        "timeout": "5s",
        "strategy": "freshness"
      }
    },
    {
      "name": "external-assets",
      "urls": [
        "https://images.igdb.com/**",
        "https://raw.githubusercontent.com/**",
        "https://*.amiiboapi.com/**",
        "https://www.pricecharting.com/**",
        "https://*.igdb.com/**"
      ],
      "cacheConfig": {
        "maxSize": 5000,
        "maxAge": "30d",
        "timeout": "10s",
        "strategy": "performance"
      }
    }
  ]
}
